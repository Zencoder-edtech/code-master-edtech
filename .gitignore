# =============================================================================
# CodeMaster EdTech — Git Ignore Rules
# =============================================================================

# Dependencies (installed via pnpm install — never commit these)
node_modules
.pnp
.pnp.js

# Next.js build output (generated by `next build`)
.next/
out/
build
.swc/

# Misc
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables (NEVER commit — contains secrets like DB password)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Turborepo cache (speeds up builds — auto-generated)
.turbo

# Compiled package output (generated by `tsc` or `tailwindcss`)
dist/

# Prisma generated client (auto-generated by `prisma generate`)
src/generated/